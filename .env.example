# ═══════════════════════════════════════════════════════════════════════════════
# Financial Investment Risk Analysis — Environment Configuration
# Copy this file to .env and fill in values before running any scripts.
# ═══════════════════════════════════════════════════════════════════════════════

# ── EC2 Public IPs (fill in after launching instances) ─────────────────────────
MASTER_PUBLIC_IP=<your-master-public-ip>
WORKER1_PUBLIC_IP=<your-worker1-public-ip>
WORKER2_PUBLIC_IP=<your-worker2-public-ip>

# ── EC2 Private IPs (for /etc/hosts and Hadoop inter-node communication) ───────
MASTER_PRIVATE_IP=<your-master-private-ip>
WORKER1_PRIVATE_IP=<your-worker1-private-ip>
WORKER2_PRIVATE_IP=<your-worker2-private-ip>

# ── Node Hostnames (used by Hadoop config XMLs) ────────────────────────────────
MASTER_HOST=master
WORKER1_HOST=worker1
WORKER2_HOST=worker2

# ── SSH ────────────────────────────────────────────────────────────────────────
SSH_USER=ubuntu
SSH_KEY_PATH=~/.ssh/id_rsa
# After generating keys on master, paste the public key here for setup-worker.sh:
# MASTER_PUBKEY=<contents of /root/.ssh/id_rsa.pub on master node>

# ── Hadoop Configuration ───────────────────────────────────────────────────────
HADOOP_VERSION=3.3.6
HDFS_REPLICATION=2
HDFS_BLOCK_SIZE_MB=128
HADOOP_HOME=/opt/hadoop
JAVA_HOME=/usr/lib/jvm/java-11-openjdk-amd64

# ── HDFS Paths ─────────────────────────────────────────────────────────────────
HDFS_INPUT=/user/hadoop/lendingclub/input
HDFS_OUTPUT_BASE=/user/hadoop/lendingclub/output

# ── MapReduce ──────────────────────────────────────────────────────────────────
MAPREDUCE_DIR=/mapreduce

# ── Go Service Ports ───────────────────────────────────────────────────────────
API_GATEWAY_PORT=8080
ORCHESTRATOR_PORT=8081
AGGREGATOR_PORT=8082
DASHBOARD_PORT=3000

# ── Inter-service addresses (inside the master container, all localhost) ────────
ORCHESTRATOR_HOST=localhost
AGGREGATOR_HOST=localhost

# ── Kaggle credentials (for automated dataset download) ────────────────────────
# Get your API key from https://www.kaggle.com/account → API → Create New Token
KAGGLE_USERNAME=<your-kaggle-username>
KAGGLE_KEY=<your-kaggle-api-key>
